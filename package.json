{
    "name": "n8n-nodes-backstage",
    "version": "0.0.1",
    "description": "n8n community node to query Backstage software catalog and TechDocs via MCP (Model Context Protocol)",
    "license": "MIT",
    "homepage": "https://github.com/jsolana/n8n-nodes-backstage",
    "keywords": [
        "n8n-community-node-package",
        "n8n",
        "backstage",
        "mcp",
        "model-context-protocol",
        "catalog",
        "techdocs",
        "developer-portal"
    ],
    "author": {
        "name": "Javier Solana",
        "email": "javier.solana@cabify.com"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/jsolana/n8n-nodes-backstage.git"
    },
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "n8n-node build && node esbuild.config.mjs",
        "build:watch": "tsc --watch",
        "dev": "n8n-node dev",
        "lint": "n8n-node lint",
        "lint:fix": "n8n-node lint --fix",
        "release": "n8n-node release",
        "prepublishOnly": ""
    },
    "files": [
        "dist"
    ],
    "n8n": {
        "n8nNodesApiVersion": 1,
        "strict": false,
        "credentials": [
            "dist/credentials/BackstageMcpApi.credentials.js"
        ],
        "nodes": [
            "dist/nodes/Backstage/Backstage.node.js",
            "dist/nodes/BackstageAiTool/BackstageAiTool.node.js"
        ]
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.12.1"
    },
    "devDependencies": {
        "@langchain/core": "^1.2.1",
        "@n8n/node-cli": "*",
        "@types/node": "^26.0.1",
        "esbuild": "^0.25.12",
        "eslint": "9.32.0",
        "n8n-workflow": "^2.16.0",
        "prettier": "3.6.2",
        "release-it": "^19.0.4",
        "typescript": "5.9.2"
    },
    "peerDependencies": {
        "@langchain/core": ">=0.3.0",
        "n8n-workflow": "*"
    }
}
